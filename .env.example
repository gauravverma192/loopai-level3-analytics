# Copy to .env (gitignored) and fill in. Never commit real secrets.

# --- Backend (apps/api) — private, server-only ---
PORT=3001

# External mock API (Loop assessment server)
MOCK_API_BASE_URL=https://assessment-6xdhr.ondigitalocean.app

# Cache: set REDIS_URL to use Redis; leave unset for in-memory cache (local dev)
# REDIS_URL=redis://localhost:6379

# Cache TTL in seconds (assignment default: 5 minutes)
CACHE_TTL_SECONDS=300

# --- Frontend (apps/web) — PUBLIC, shipped to the browser. No secrets here. ---
# Only VITE_-prefixed vars are exposed to client code via import.meta.env.
# VITE_API_URL=/api
# VITE_WS_URL=wss://assessment-6xdhr.ondigitalocean.app
