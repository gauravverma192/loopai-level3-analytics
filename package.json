{
  "name": "loopai-level3-analytics",
  "private": true,
  "version": "0.1.0",
  "description": "Level 3 SDE2 — performance-optimized analytics platform with caching, batch API, and optimized React UI.",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:vercel-api": "esbuild api/entry.ts --bundle --platform=node --format=cjs --outfile=api/index.js",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
